{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": ".next",
    "noEmit": true,
    "allowJs": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@solar/db": ["../../packages/db/src/index.ts"],
      "@solar/db/*": ["../../packages/db/src/*"],
      "@solar/contracts": ["../../packages/contracts/src/index.ts"],
      "@solar/contracts/*": ["../../packages/contracts/src/*"],
      "@solar/auth": ["../../packages/auth/src/index.ts"],
      "@solar/auth/*": ["../../packages/auth/src/*"],
      "@solar/storage": ["../../packages/storage/src/index.ts"],
      "@solar/storage/*": ["../../packages/storage/src/*"],
      "@solar/email": ["../../packages/email/src/index.ts"],
      "@solar/email/*": ["../../packages/email/src/*"],
      "@solar/ui": ["../../packages/ui/src/index.ts"],
      "@solar/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
