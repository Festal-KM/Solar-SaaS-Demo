// Solar-SaaS — initial schema (auth / tenant / role / RLS-target tables)
//
// Source of truth: docs/05-program-design.md §3.2 (認証・テナント) and §3.7 (AuditLog).
// Domain tables (master / event / customer / deal / monthly etc.) land in SP-02..06.
// RLS DDL (docs/05 §3.9) is added in T-01-04 as a separate migration.
//
// Conventions (docs/05 §3.1):
//   - PK: `id String @id @default(cuid())`. AuditLog uses BigInt for monotonic ordering.
//   - Timestamps: every mutable row has `createdAt` / `updatedAt`.
//   - Tenant key: `wholesalerId` for wholesaler-internal data, `relationshipId` for
//     cross-tenant transactions, `dealerId` for dealer-internal data.
//   - Money: `Decimal(14,2)`. Percentage: `Decimal(5,2)`. Float is forbidden.
//   - Status: every state column is a Prisma `enum`.
//   - Soft delete: master tables use `isActive`. Transactions are never physically deleted.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

// ---------------------------------------------------------------------------
// Enums — auth / tenant
// ---------------------------------------------------------------------------

enum TenantType {
  WHOLESALER
  DEALER
}

enum TenantPlan {
  PILOT
  SMALL
  MEDIUM
  LARGE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum PiiMaskingMode {
  // MASKED  — DEALER メンバ向け既定（電話下 4 桁／市区町村まで／姓のみ）
  // FULL    — WHOLESALER 管理者向け既定（マスク無し）
  // PARTIAL — 電話下 4 桁可視 + 住所と氏名はマスクの中間モード
  MASKED
  FULL
  PARTIAL
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum AppRole {
  SAAS_ADMIN
  WHOLESALER_ADMIN
  WHOLESALER_EVENT_TEAM
  WHOLESALER_CALL_TEAM
  WHOLESALER_DIRECT_SALES
  WHOLESALER_FIELD_STAFF
  DEALER_ADMIN
  DEALER_STAFF
}

enum RelationshipStatus {
  ACTIVE
  SUSPENDED
}

enum DealerScope {
  // APPOINTMENT_ONLY     — アポ取りまで
  // FIRST_VISIT          — 初訪まで
  // FULL_CLOSING         — 契約まで一気通貫
  APPOINTMENT_ONLY
  FIRST_VISIT
  FULL_CLOSING
}

// Full AuditAction set per docs/05 §3.7. SP-01 bootstrapped the minimal subset;
// T-06-01 completes the enum so MonthlyReport / monthly-close actions are typeable.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  PUBLISH
  UNPUBLISH
  CANCEL
  FINALIZE
  UNLOCK
  MANUAL_ADJUST
  REVEAL_PII
  ROLE_CHANGE
  RELATION_SUSPEND
  RELATION_RESUME
}

// ---------------------------------------------------------------------------
// Models — auth / tenant
// ---------------------------------------------------------------------------

model Tenant {
  id        String       @id @default(cuid())
  type      TenantType
  name      String
  plan      TenantPlan? // dealer is null
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users             User[]
  wholesalerSetting WholesalerSettings?
  asWholesaler      Relationship[]      @relation("Wholesaler")
  asDealer          Relationship[]      @relation("Dealer")
  inviteCodes       InviteCode[]
  planHistory       TenantPlanHistory[]

  @@index([type, status])
}

// Append-only audit of every Tenant.plan change. Visible only to SAAS_ADMIN
// — twin-keyed by `tenantId` for retrieval and by `createdAt` for sort.
// docs/02 §F-005 / docs/05 §3.2.
//
// `planBefore` may be null when a tenant is first transitioned out of a null
// plan state (legacy DEALER tenants, or a wholesaler whose plan was unset).
model TenantPlanHistory {
  id            String      @id @default(cuid())
  tenantId      String
  planBefore    TenantPlan?
  planAfter     TenantPlan
  effectiveFrom DateTime
  changedBy     String
  note          String?
  createdAt     DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model WholesalerSettings {
  wholesalerId         String         @id
  cancelDeadlineDays   Int            @default(8) // F-015
  fiscalYearStartMonth Int            @default(4) // F-016 (1..12)
  piiMaskingMode       PiiMaskingMode @default(MASKED) // OQ-2 default
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  // App layer enforces that wholesalerId references a WHOLESALER tenant
  // (CHECK constraint not expressible in Prisma DSL — see docs/05 §3.9).
  tenant Tenant @relation(fields: [wholesalerId], references: [id], onDelete: Cascade)
}

model User {
  id                String     @id @default(cuid())
  tenantId          String
  email             String     @unique
  passwordHash      String? // null while INVITED
  name              String
  status            UserStatus @default(INVITED)
  twoFactorRequired Boolean    @default(false)
  sessionVersion    Int        @default(0) // bump to force logout
  lastLoginAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles               UserRole[]
  totpSecret          TotpSecret?
  backupCodes         BackupCode[]
  loginAttempts       LoginAttempt[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]
  notificationPrefs   NotificationPreference[]

  @@index([tenantId, status])
  @@index([email])
}

model UserRole {
  userId     String
  role       AppRole
  assignedAt DateTime @default(now())
  assignedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@index([role])
}

model Relationship {
  id           String             @id @default(cuid())
  wholesalerId String
  dealerId     String
  status       RelationshipStatus @default(ACTIVE)
  defaultScope DealerScope        @default(FULL_CLOSING)
  // 加盟店番号（卸業者が二次店に割り当てる識別番号、例: ERP12）。
  // 二次店マスタで編集する。wholesaler×dealer 単位なので Relationship に持つ。
  franchiseNo  String?
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  wholesaler                 Tenant                     @relation("Wholesaler", fields: [wholesalerId], references: [id])
  dealer                     Tenant                     @relation("Dealer", fields: [dealerId], references: [id])
  incentiveRates             IncentiveRate[]
  eventCandidateVisibilities EventCandidateVisibility[]
  dealerPreferences          DealerPreference[]
  eventDealers               EventDealer[]
  preCallNotifications       PreCallNotification[]
  incentives                 Incentive[]
  monthlyReports             MonthlyReport[]
  commissionRate             DealerCommissionRate?

  @@unique([wholesalerId, dealerId])
  @@index([wholesalerId, status])
  @@index([dealerId, status])
}

model InviteCode {
  id           String    @id @default(cuid())
  wholesalerId String
  codeHash     String    @unique // 平文は発行直後に破棄
  expiresAt    DateTime
  maxUses      Int       @default(1)
  usedCount    Int       @default(0)
  createdBy    String
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  wholesaler Tenant @relation(fields: [wholesalerId], references: [id])

  @@index([wholesalerId, expiresAt])
}

model UserInvitation {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       AppRole
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  invitedBy  String
  createdAt  DateTime  @default(now())

  @@index([tenantId, email])
}

// Password reset tokens (F-003 / docs/05 §6.10).
//
// Email-based password reset. The plaintext token (32 random bytes hex) is
// embedded in the reset URL; only the argon2id hash is persisted. A token is
// valid for 30 minutes and is single-use — `usedAt` is stamped on successful
// reset and the row stays around for the AuditLog cross-reference.
//
// RLS: rows are scoped via the related `User.tenantId`. The auth layer always
// runs under `SYSTEM_TENANT_CONTEXT` (isSaasAdmin=true) so the policy passes.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model TotpSecret {
  userId      String    @id
  secretEnc   String // symmetric encrypted with env key
  activatedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String // argon2id
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ip        String
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  // F-001 lock window probe (5 failures within 15 minutes per email).
  @@index([email, createdAt])
  @@index([ip, createdAt])
}

// Auth.js v5 session helper (JWT verification accelerator + forced logout).
model Session {
  id             String   @id @default(cuid())
  userId         String
  sessionToken   String   @unique
  sessionVersion Int
  expiresAt      DateTime
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// AuditLog — docs/05 §3.7 (extended in SP-07 to cover all AuditAction values)
// ---------------------------------------------------------------------------

model AuditLog {
  id          BigInt      @id @default(autoincrement())
  actorUserId String?
  tenantId    String
  targetType  String
  targetId    String
  action      AuditAction
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
  @@index([actorUserId, createdAt])
}

// ---------------------------------------------------------------------------
// Enums — masters (SP-02 / docs/05 §3.3)
// ---------------------------------------------------------------------------

enum VenueContractType {
  // FIXED       — 固定費型（月額・回数固定で支払）
  // PERFORMANCE — 成果報酬型（契約獲得数や粗利の % で支払）
  // OTHER       — その他（個別契約）
  FIXED
  PERFORMANCE
  OTHER
}

// ラインイベントの契約ステータス（確認中 / 確定 / 中止）。
enum LineEventStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

// ラインイベントのアサインステータス（確定 / 調整中）。
enum LineAssignStatus {
  CONFIRMED
  ADJUSTING
}

enum ProductCategory {
  PANEL
  BATTERY
  POWER_CONDITIONER
  MOUNT
  OTHER_PART
  SET
}

enum IncentiveTargetType {
  // PROJECT_PROFIT   — 案件粗利（顧客契約全体の粗利）に対する率
  // WHOLESALE_PROFIT — 卸粗利（卸→二次店マージン）に対する率
  // MANUAL           — 手動設定（金額直指定）
  PROJECT_PROFIT
  WHOLESALE_PROFIT
  MANUAL
}

// ---------------------------------------------------------------------------
// Models — masters (SP-02 / docs/05 §3.3)
//
// All five tables are wholesaler-scoped (directly via `wholesalerId` or
// transitively via Product/Relationship). RLS policies live in the
// `*_masters` migration and enforce `wholesalerId = current_wholesaler_id`
// (plus `is_saas_admin` bypass and a relationship-membership branch for
// IncentiveRate). Postgres CHECK constraints on `effectiveFrom < effectiveTo`
// are also added there (Prisma DSL does not express CHECK).
// ---------------------------------------------------------------------------

model VenueProvider {
  id              String             @id @default(cuid())
  wholesalerId    String
  name            String
  contactName     String?
  phone           String?
  email           String?
  postalCode      String?
  address         String?
  area            String?
  contractType    VenueContractType?
  // FIXED 契約の月額／回数費用（円）
  fixedFee        Decimal?           @db.Decimal(14, 2)
  // PERFORMANCE 契約の成果報酬率（% 0..100）
  performanceRate Decimal?           @db.Decimal(5, 2)
  note            String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  venueNegotiations VenueNegotiation[]
  stores            Store[]

  @@index([wholesalerId, isActive])
}

// エリアマスタの種別。
// EVENT    — イベントの開催エリア（場所提供元 / イベント候補に紐づく）
// CUSTOMER — 顧客のエリア（営業対象エリアの区分）
enum AreaType {
  EVENT
  CUSTOMER
}

// エリアマスタ — 卸業者ごとに管理する。EVENT (開催エリア) と CUSTOMER
// (顧客エリア) を `type` 列で区別する。同名のエリアを両方の用途で登録可能
// （例: 「東京都」をイベント用と顧客用で別レコード）。`description` は補助
// メモ（運用ルール・対象市区町村など）の自由テキスト。
model Area {
  id           String   @id @default(cuid())
  wholesalerId String
  name         String
  type         AreaType @default(EVENT)
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([wholesalerId, type, isActive])
  @@index([wholesalerId, isActive])
}

// 店舗マスタ — チェーン (VenueProvider) の支店を卸業者ごとに管理する。
// venueProviderId は親チェーンへの参照（nullable: 親未紐づけの古いレコード
// と互換）。SetNull で親削除時にも残せるが、現状の VenueProvider 廃止フロー
// は isActive フラグのみで物理削除しないので実害なし。
model Store {
  id              String   @id @default(cuid())
  wholesalerId    String
  venueProviderId String?
  name            String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  venueProvider VenueProvider? @relation(fields: [venueProviderId], references: [id], onDelete: SetNull)

  @@index([wholesalerId, isActive])
  @@index([venueProviderId])
}

// ラインイベント — 懇意の場所提供元と月単位で複数開催日を契約するイベント。
// 単発イベント（EventCandidate, 1日1件）と異なり、scheduledDates に複数の
// 開催日（YYYY-MM-DD 文字列の配列）を保持する。
model LineEvent {
  id              String             @id @default(cuid())
  wholesalerId    String
  venueProviderId String?
  name            String
  // 'YYYY-MM' — 対象月。単発の EventCandidate.targetMonth と同じ運用。
  targetMonth     String
  area            String?
  address         String?
  // ISO date strings (YYYY-MM-DD) の配列。月内の開催日を保持する。
  scheduledDates  Json
  contractType    VenueContractType?
  // FIXED 契約の日当たり報酬額（円）。
  fixedFee        Decimal?           @db.Decimal(14, 2)
  // PERFORMANCE 契約の成果報酬率（% 0..100）。
  performanceRate Decimal?           @db.Decimal(5, 2)
  contractNote    String?
  status          LineEventStatus    @default(DRAFT)
  // アサイン情報。assignMode は EventMode を再利用（SELF/DEALER/JOINT）。
  // assignStaffIds は User.id 配列、assignDealerIds は Relationship.id 配列を
  // JSON で保持する。
  assignMode      EventMode?
  assignStatus    LineAssignStatus?
  assignStaffIds  Json?
  assignDealerIds Json?
  assignNote      String?
  createdBy       String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([wholesalerId, targetMonth])
  @@index([wholesalerId, status])
}

// 二次店レーン希望 — 二次店が月単位で「希望するレーン（＝希望場所 × 希望開催日）」を
// 希望順位付きで複数件提出する（F-060）。旧仕様は卸業者が作成した確定レーン(LineEvent)
// を二次店が優先順位付けするトップダウン構造だったが、新仕様は二次店が確定レーンに依存
// せず希望場所・希望開催日を自由記述で提出するボトムアップ構造（docs/05 §3.4 / §9 申し送り）。
model LanePreference {
  id             String   @id @default(cuid())
  wholesalerId   String
  relationshipId String
  // 'YYYY-MM' — 対象月。
  targetMonth    String
  // 特記事項（旧 comment を改称・維持。バックフィルで comment→note コピー）。
  note           String?
  submittedAt    DateTime @default(now())
  submittedBy    String

  items LanePreferenceItem[]

  // 同一二次店 × 同一月の重複提出は不可（更新扱い）。
  @@unique([relationshipId, targetMonth])
  @@index([wholesalerId, targetMonth])
}

// レーン希望の各明細（希望順位付き）。priority=1 が希望①。
// venueLabel が一次ソース（必須）。venueProviderId / storeId / lineEventId は
// マスタ・確定レーンへの「任意リンク」で FK を張らず id 文字列で柔リンク
// （loader 層で findMany → Map 結合。VenueProvider 解決と同方針）。
model LanePreferenceItem {
  id               String @id @default(cuid())
  lanePreferenceId String
  priority         Int
  // 希望場所の表示用ラベル（例「カインズ 大宮店」）。一次ソース・必須。
  // マスタ未登録の場所も二次店が自由記述で提出できる。
  venueLabel       String
  // マスタ任意リンク（場所提供元 / 店舗）。NULL 許容・柔リンク（FK なし）。
  venueProviderId  String?
  storeId          String?
  // 確定レーン(LineEvent)への任意リンク。旧仕様で必須だった参照を NULL 許容に降格。
  lineEventId      String?
  // 希望開催日。週単位の複数希望日（'YYYY-MM-DD' の Json 配列）。
  // LineEvent.scheduledDates と方式を統一（§3.4 / Open Q26）。
  desiredDates     Json?
  // レーン別メモ（任意）。
  memo             String?

  lanePreference LanePreference @relation(fields: [lanePreferenceId], references: [id], onDelete: Cascade)

  @@index([lanePreferenceId])
}

model Product {
  id            String          @id @default(cuid())
  wholesalerId  String
  category      ProductCategory
  maker         String
  name          String
  modelNo       String?
  // 容量（kW など。unit 列に単位を保持）
  capacity      Decimal?        @db.Decimal(10, 2)
  unit          String
  // 卸の仕入値（二次店には絶対に開示しない／docs/03 §4.3）
  purchasePrice Decimal         @db.Decimal(14, 2)
  // 二次店向け卸値
  dealerPrice   Decimal         @db.Decimal(14, 2)
  // エンドユーザー向け参考売価
  listPrice     Decimal         @db.Decimal(14, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean         @default(true)
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdBy     String

  priceHistory ProductPriceHistory[]
  // F-063: 顧客のご提案商材（任意の商品マスタ参照）の逆リレーション（docs/05 §17.3）。
  customersProposed Customer[] @relation("CustomerProposedProduct")

  @@index([wholesalerId, category, isActive])
  @@index([wholesalerId, effectiveFrom, effectiveTo])
}

model ProductPriceHistory {
  id        String   @id @default(cuid())
  productId String
  before    Json
  after     Json
  // User.id — append-only audit of who initiated the price change
  changedBy String
  changedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, changedAt])
}

model Installer {
  id           String   @id @default(cuid())
  wholesalerId String
  name         String
  phone        String?
  email        String?
  contactName  String?
  area         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  constructions Construction[]

  @@index([wholesalerId, isActive])
}

model IncentiveRate {
  id             String              @id @default(cuid())
  relationshipId String
  targetType     IncentiveTargetType
  // % (0..100)
  rate           Decimal             @db.Decimal(5, 2)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  note           String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      String

  relationship Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@index([relationshipId, effectiveFrom, effectiveTo])
}

// 手数料設定 — 二次店ごとに「トスアップ率（紹介のみ）」と「クロージング率
// （契約完了まで）」の 2 種を保持する。`IncentiveRate` は粗利ベースの異なる概念
// なので新規モデルで分離。1 つの relationship につき 1 件（@unique）。
model DealerCommissionRate {
  id              String                       @id @default(cuid())
  wholesalerId    String
  relationshipId  String                       @unique
  // % (0..100)
  tossUpRate      Decimal                      @db.Decimal(5, 2)
  closingRate     Decimal                      @db.Decimal(5, 2)
  applyFrom       DateTime
  applyTo         DateTime?
  updatedByUserId String
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  relationship    Relationship                 @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  changes         DealerCommissionRateChange[]

  @@index([wholesalerId])
}

// 手数料設定の変更履歴。保存時に差分サマリを 1 行追記する。
model DealerCommissionRateChange {
  id              String   @id @default(cuid())
  rateId          String
  changedByUserId String
  summary         String
  createdAt       DateTime @default(now())

  rate DealerCommissionRate @relation(fields: [rateId], references: [id], onDelete: Cascade)

  @@index([rateId, createdAt])
}

// ---------------------------------------------------------------------------
// Enums — event flow (SP-03 / docs/05 §3.4)
// ---------------------------------------------------------------------------

// VenueNegotiation lifecycle. Allowed transitions are enforced at the service
// layer (T-03-02). See docs/05 §3.4 for the canonical state machine.
enum VenueNegotiationStatus {
  NOT_CONTACTED
  CONTACTING
  CONDITION_REVIEW
  FEASIBLE
  INFEASIBLE
  FIXED
  CANCELLED
}

// EventCandidate publication lifecycle. DRAFT → OPEN (受付中) → CLOSED (締切) →
// DECIDED (開催体制決定) or CANCELLED (中止).
enum EventCandidateStatus {
  DRAFT
  OPEN
  CLOSED
  DECIDED
  CANCELLED
}

// Event hosting mode chosen at decision time.
//   SELF      — 自社のみ開催
//   DEALER    — 二次店単独開催
//   JOINT     — 共同開催
//   CANCELLED — 中止（イベント候補のキャンセル後に Event 自体は作らないが、
//                変更履歴用に保持されるケースがある）
enum EventMode {
  SELF
  DEALER
  JOINT
  CANCELLED
}

enum EventStatus {
  PLANNED
  ONGOING
  CLOSED
  CANCELLED
}

// Shift role for EventShift (T-03-10).
enum ShiftRole {
  LEAD
  CATCH
  RECEPTION
  PITCH
  OTHER
}

enum ShiftStatus {
  ASSIGNED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
}

// ---------------------------------------------------------------------------
// Models — event flow (SP-03 / docs/05 §3.4)
//
// Tenant scoping (RLS migration mirrors these):
//   - VenueNegotiation / EventCandidate / Event   → wholesalerId
//   - EventCandidateVisibility / DealerPreference
//     / EventDealer                                → relationshipId
//   - EventShift / EventChange                     → parent Event.wholesalerId
//                                                    (correlated EXISTS)
//
// docs/05 §3.4 also defines EventReport (event reporting) and Appointment /
// Customer.sourceEvent (顧客起点). Those models land in SP-04 / SP-05 so the
// `Event` back-relations for them are deliberately omitted here and will be
// added in the matching migration.
// ---------------------------------------------------------------------------

model VenueNegotiation {
  id              String                 @id @default(cuid())
  wholesalerId    String
  venueProviderId String
  // ISO date strings (yyyy-mm-dd) for candidate dates the venue offered.
  candidateDates  Json
  decidedDate     DateTime?
  contractType    VenueContractType?
  fixedFee        Decimal?               @db.Decimal(14, 2)
  performanceRate Decimal?               @db.Decimal(5, 2)
  conditionNote   String?
  status          VenueNegotiationStatus @default(NOT_CONTACTED)
  nextAction      String?
  assigneeId      String?
  note            String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  venueProvider VenueProvider @relation(fields: [venueProviderId], references: [id])

  @@index([wholesalerId, status])
  @@index([wholesalerId, venueProviderId])
}

model EventCandidate {
  id                 String               @id @default(cuid())
  wholesalerId       String
  venueProviderId    String?
  venueNegotiationId String?
  // 'YYYY-MM' — kept as TEXT to keep the unique-month groupby trivial.
  targetMonth        String
  scheduledDate      DateTime
  storeName          String
  address            String?
  area               String?
  // 二次店からの希望提出締切。アプリ層で「期限後の更新」を 409 にする。
  deadlineAt         DateTime
  contractType       VenueContractType?
  fixedFee           Decimal?             @db.Decimal(14, 2)
  performanceRate    Decimal?             @db.Decimal(5, 2)
  // 契約条件のメモ（固定費/成果報酬それぞれの補足）。
  contractNote       String?
  // 卸業者内部メモ。二次店向け DTO では絶対に返さない（docs/05 §4.5）。
  internalNote       String?
  status             EventCandidateStatus @default(DRAFT)
  publishedAt        DateTime?
  createdBy          String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  visibilities EventCandidateVisibility[]
  preferences  DealerPreference[]
  event        Event?

  @@index([wholesalerId, targetMonth, status])
  @@index([wholesalerId, scheduledDate])
}

model EventCandidateVisibility {
  eventCandidateId String
  relationshipId   String
  isVisible        Boolean   @default(true)
  notifiedAt       DateTime?

  eventCandidate EventCandidate @relation(fields: [eventCandidateId], references: [id], onDelete: Cascade)
  relationship   Relationship   @relation(fields: [relationshipId], references: [id])

  @@id([eventCandidateId, relationshipId])
  @@index([relationshipId, isVisible])
}

model DealerPreference {
  id               String   @id @default(cuid())
  eventCandidateId String
  relationshipId   String
  targetMonth      String
  priority         Int?
  // ISO date string array of dates the dealer can attend.
  availableDates   Json?
  availablePeople  Int?
  comment          String?
  submittedAt      DateTime @default(now())
  submittedBy      String

  eventCandidate EventCandidate @relation(fields: [eventCandidateId], references: [id])
  relationship   Relationship   @relation(fields: [relationshipId], references: [id])

  // F-021: 同一二次店からの重複提出は不可（更新扱い）。同じ店舗に複数の二次店が
  // 応募することは許可されるため、(eventCandidateId, relationshipId) UNIQUE のみ。
  @@unique([eventCandidateId, relationshipId])
  @@index([relationshipId, targetMonth])
}

model Event {
  id               String      @id @default(cuid())
  wholesalerId     String
  eventCandidateId String      @unique
  mode             EventMode
  requiredPeople   Int?
  decidedBy        String
  decidedAt        DateTime    @default(now())
  status           EventStatus @default(PLANNED)
  note             String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  eventCandidate EventCandidate @relation(fields: [eventCandidateId], references: [id])
  dealers        EventDealer[]
  shifts         EventShift[]
  reports        EventReport[]
  changes        EventChange[]
  appointments   Appointment[]
  customers      Customer[]

  @@index([wholesalerId, status])
}

model EventDealer {
  eventId        String
  relationshipId String
  // null のときは Relationship.defaultScope を採用。
  scopeOverride  DealerScope?
  assignedBy     String
  assignedAt     DateTime     @default(now())

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  relationship Relationship @relation(fields: [relationshipId], references: [id])

  @@id([eventId, relationshipId])
  @@index([relationshipId])
}

model EventShift {
  id           String      @id @default(cuid())
  eventId      String
  userId       String
  role         ShiftRole
  startPlanned DateTime
  endPlanned   DateTime
  startActual  DateTime?
  endActual    DateTime?
  status       ShiftStatus @default(ASSIGNED)
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // F-025: 同一ユーザの同時刻開始シフトは禁止。アプリ層が「終了時刻」も含めた
  // 区間重複を事前チェックし、DB は最終ガードとして開始時刻の UNIQUE で抑える。
  @@unique([userId, startPlanned])
  @@index([eventId])
  @@index([userId, startPlanned, endPlanned])
}

model EventChange {
  id        String   @id @default(cuid())
  eventId   String
  before    Json
  after     Json
  changedBy String
  changedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, changedAt])
}

// ---------------------------------------------------------------------------
// Enums — execution: event report / customer / appointment / pre-call (SP-04)
// ---------------------------------------------------------------------------

enum EventReportType {
  START
  END
  RESULT
}

enum CustomerStatus {
  NEW
  PRE_CALL_WAIT
  PRE_CALL_DONE
  VISIT_PLANNED
  IN_NEGOTIATION
  CONTRACTED
  LOST
  IN_CONSTRUCTION
  COMPLETED
}

enum AcquisitionChannel {
  EVENT
  WALK_IN
  TELE
  REFERRAL
  OTHER
}

enum AppointmentStatus {
  UNCONFIRMED
  PRE_CALL_DONE
  VISITED
  ABSENT
  CANCELLED
  RESCHEDULED
}

enum PreCallResult {
  APPROVED
  ABSENT
  CALLBACK
  CANCELLED
  RESCHEDULED
}

enum PreCallNotificationStatus {
  PENDING
  SENT
  ACKNOWLEDGED
}

// ---------------------------------------------------------------------------
// Models — execution: event report / customer / appointment / pre-call (SP-04)
// docs/05 §3.5
// ---------------------------------------------------------------------------

model EventReport {
  id              String          @id @default(cuid())
  eventId         String
  type            EventReportType
  reporterUserId  String
  reporterOrgType TenantType
  payload         Json
  createdAt       DateTime        @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, type])
}

model Customer {
  id                         String             @id @default(cuid())
  wholesalerId               String
  ownerRelationshipId        String?
  name                       String
  kana                       String?
  phone                      String
  email                      String?
  postalCode                 String?
  address                    String?
  // 連絡先構造化（docs/05 §16-A）。住所は当面 address と併存。
  prefecture                 String? // 都道府県
  city                       String? // 市区町村
  addressLine                String? // 番地以降
  birthDate                  DateTime? // 生年月日（年齢は表示時に算出）
  buildYear                  DateTime? // 築年日
  tossDept                   String? // トス部署
  belongDept                 String? // 所属部署
  area                       String? // 顧客のエリア（エリアマスタ名を保持。未設定時は住所から導出表示）
  housingType                String?
  pvInstalled                Boolean?
  batteryInstalled           Boolean?
  electricBill               String?
  household                  String?
  channel                    AcquisitionChannel
  // 流入経路（顧客情報で手動選択）: "EVENT" | "OUTBOUND_CALL" | "DIRECT_VISIT"。
  // 既存の channel（獲得チャネル、登録時確定・不変）とは別に、顧客情報セクションで
  // 編集できる手動値として保持する。
  inflowRoute                String?
  sourceEventId              String?
  registeredByUserId         String
  registeredByOrgType        TenantType
  registeredByRelationshipId String?
  // 顧客対応の担当者は 2 役割で管理する：トスアップ担当（見込みを引き上げた人）と
  // クロージング担当（契約クロージングを担う人）。どちらも任意（未設定可）で、
  // 担当主体は「自社社員(User)」または「二次店(Relationship)」のいずれか（排他）。
  tossUpUserId               String?
  tossUpRelationshipId       String?
  closingUserId              String?
  closingRelationshipId      String?
  status                     CustomerStatus     @default(NEW)
  note                       String?
  // 顧客詳細で手動管理する 3 ステータス + 各詳細項目（自動導出ではなく手動値）。
  contractStatus             String             @default("negotiating")
  contractPlan               String?
  contractAmount             Int? // 契約金額（円・税込）
  contractExpectedDate       DateTime?
  constructionStatus         String             @default("not_started")
  constructionPlannedDate    DateTime?
  constructionCompletedDate  DateTime?
  constructionVendor         String? // 施工の対応事業者名
  subsidyStatus              String             @default("none")
  subsidyType                String?
  subsidySubmittedDate       DateTime?
  subsidyGrantedDate         DateTime?
  // 商談履歴タブで手動管理する状況。マエカク状況（"present" | "absent"）/
  // 次回アクション（自由記述）/ 次回アポ日程（日付）。商談ステータスは contractStatus を流用。
  maekakuStatus              String?
  nextAction                 String?
  nextAppointmentAt          DateTime?
  // F-063 住環境・家族属性ヒアリング（docs/05 §17）。連絡先 2 系統分離・家族属性・
  // 案内者・提案商材・マエカク希望日時。phone は当面併存（後方互換 §17.6）。
  landlinePhone              String?            // 固定電話
  mobilePhone                String?            // 携帯電話
  husbandAge                 Int?               // ご主人年齢（ヒアリング値。本人年齢算出とは別概念）
  wifeAge                    Int?               // 奥様年齢
  childAge                   Int?               // お子様年齢（代表 1 名・MVP）
  guideAttendee              GuideAttendee?     // 案内者（faceToFace と別概念・別列）
  faceToFace                 Boolean?           // 主権者同席フラグ（guideAttendee と別列）
  proposedProduct            String?            // ご提案商材（自由記述・トスアップ時）
  proposedProductId          String?            // ご提案商材（商品マスタ参照、任意）
  maekakuPreferredAt         DateTime?          // マエカク電話希望日時（maekakuStatus と併存）
  // 電気契約・設備（基本情報タブで手動編集する識別子・ステータス。全て自由記述・nullable）。
  // 注: equipmentId は Customer 列であり、契約の equipmentSerialId（projectInfo.fields.equipmentId）
  // とは別概念・別ラベル namespace（customer.detail.fields.equipmentId）。
  electricContractStatus     String?            // 電気契約状況（自由記述）
  electricAccountNo          String?            // お客様番号（電力会社）
  supplyPointNo              String?            // 供給地点特定番号
  equipmentId                String?            // 設備ID（自由記述）
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  appointments Appointment[]
  deals        Deal[]
  contracts    Contract[]
  sourceEvent  Event?        @relation(fields: [sourceEventId], references: [id])
  activities   CustomerActivity[]
  tasks        CustomerTask[]
  files        CustomerFile[]
  messages     CustomerMessage[]
  existingEquipments CustomerExistingEquipment[]
  proposedProductRef Product? @relation("CustomerProposedProduct", fields: [proposedProductId], references: [id], onDelete: SetNull)

  @@index([wholesalerId, phone])
  @@index([wholesalerId, status, createdAt])
  @@index([ownerRelationshipId])
}

// F-063 住環境・家族属性ヒアリング（docs/05 §17）。
// 案内者: ご主人のみ / 奥様のみ / ご夫婦お揃い / その他。
enum GuideAttendee {
  HUSBAND
  WIFE
  BOTH
  OTHER
}

// 既設設備カテゴリ（ガス給湯機 / エコキュート / 太陽光）。ContractEquipment の
// EquipmentCategory（§16.3）とは別 enum（値域・意味が異なるため共有しない）。
enum ExistingEquipmentCategory {
  GAS_WATER_HEATER
  ECO_CUTE
  PV
}

// 設置有無 3 値: あり / なし / 不明。
enum ExistingEquipmentPresence {
  YES
  NO
  UNKNOWN
}

// 既設設備の現況（ヒアリング時点。ContractEquipment とは別概念・別テーブル）。
// !! ContractEquipment（§16-C, 契約後の販売・施工設備のスペック明細）と混同しない。
//    本テーブルは提案前のクロスセル判定材料であり、契約・価格・粗利に一切連動しない。
// テナント分離は親 Customer.wholesalerId 経由の相関 EXISTS（RLS はマイグレーション参照／§17.4）。
model CustomerExistingEquipment {
  id          String                    @id @default(cuid())
  customerId  String
  category    ExistingEquipmentCategory
  installed   ExistingEquipmentPresence @default(UNKNOWN) // 設置有無
  installDate DateTime?                 // 設置日（ECO_CUTE/PV。未来日不可・§17.4）
  maker       String?                   // メーカー（ECO_CUTE/PV）
  capacityKw  Decimal?                  @db.Decimal(8, 2) // 容量[kW]（PV のみ・0 以上）
  panelCount  Int?                      // 枚数（PV のみ・0 以上）
  // attributes Json キー（任意）: model（機種・型番）, note（補足）
  attributes  Json?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // 1 顧客 × 1 カテゴリ 1 行（ガス給湯機/エコキュート/太陽光は各 1 行）。
  @@unique([customerId, category])
  @@index([customerId])
}

// 商談履歴（手入力のアクティビティログ）。顧客詳細の「新規記録」で作成。
// テナント分離は Customer.wholesalerId 経由の相関 EXISTS（RLS はマイグレーション参照）。
model CustomerActivity {
  id              String   @id @default(cuid())
  customerId      String
  occurredAt      DateTime
  category        String
  detail          String
  // 見積提示カテゴリ（category = "quote"）のときの提示金額（円）。それ以外は null。
  amount          Int?
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tasks    CustomerTask[]
  files    CustomerFile[]

  @@index([customerId, occurredAt])
}

// 発生タスク（商談履歴に紐づく ToDo）。タスク一覧タイルにも表示。
model CustomerTask {
  id              String    @id @default(cuid())
  customerId      String
  activityId      String?
  content         String
  dueDate         DateTime?
  assigneeUserId  String?
  done            Boolean   @default(false)
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  activity CustomerActivity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([customerId, dueDate])
  @@index([activityId])
}

// 顧客ファイルの用途カテゴリ。GENERAL=関連ファイルタブ、APPLICATION=設置申請タブの申請関連ドキュメント。
enum CustomerFileCategory {
  GENERAL
  APPLICATION
}

// 関連ファイル（R2 にアップロードした添付）。fileKey は R2 オブジェクトキー。
model CustomerFile {
  id               String               @id @default(cuid())
  customerId       String
  activityId       String?
  fileKey          String
  fileName         String
  contentType      String?
  size             Int?
  category         CustomerFileCategory @default(GENERAL)
  uploadedByUserId String
  createdAt        DateTime             @default(now())

  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  activity CustomerActivity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([customerId, category, createdAt])
  @@index([activityId])
}

// 顧客ごとのチャット（担当者間のやり取り）。テナント分離は Customer.wholesalerId
// 経由の相関 EXISTS（CustomerActivity と同パターン）。
model CustomerMessage {
  id           String   @id @default(cuid())
  customerId   String
  authorUserId String
  body         String
  createdAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model Appointment {
  id                     String            @id @default(cuid())
  customerId             String
  eventId                String?
  scheduledAt            DateTime
  location               String?
  acquiredByUserId       String
  acquiredOrgType        TenantType
  acquiredRelationshipId String?
  appointmentType        String?
  status                 AppointmentStatus @default(UNCONFIRMED)
  note                   String?
  // F-063: アポイント取得日（現 createdAt 近似運用を明示項目化／docs/05 §17.1.7）。
  acquiredAt             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  event    Event?   @relation(fields: [eventId], references: [id])
  preCall  PreCall?

  @@index([customerId])
  @@index([status, scheduledAt])
  @@index([acquiredRelationshipId])
}

model PreCall {
  id                     String        @id @default(cuid())
  appointmentId          String        @unique
  calledAt               DateTime
  visitConfirmedAt       DateTime?
  visitConfirmedLocation String?
  personConfirmed        Boolean       @default(false)
  result                 PreCallResult
  cancelRequested        Boolean       @default(false)
  rescheduleRequested    Boolean       @default(false)
  note                   String?
  nextAction             String?
  calledByUserId         String
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  appointment   Appointment           @relation(fields: [appointmentId], references: [id])
  notifications PreCallNotification[]

  @@index([calledAt])
}

model PreCallNotification {
  id             String                    @id @default(cuid())
  preCallId      String
  relationshipId String
  status         PreCallNotificationStatus @default(PENDING)
  notifiedAt     DateTime?
  acknowledgedAt DateTime?
  note           String?

  preCall      PreCall      @relation(fields: [preCallId], references: [id])
  relationship Relationship @relation(fields: [relationshipId], references: [id])

  @@index([relationshipId, status])
}

