{
  "name": "solar-saas",
  "version": "0.0.0",
  "private": true,
  "description": "Solar wholesale / dealer sales-management SaaS (multi-tenant)",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm --filter @solar/db run build && pnpm -r --parallel --filter '!@solar/db' run build",
    "dev": "pnpm -F @solar/web dev",
    "dev:worker": "pnpm -F @solar/worker dev",
    "typecheck": "pnpm -r --parallel run typecheck",
    "lint": "pnpm -r --parallel run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "test": "pnpm -r --parallel run test",
    "test:e2e": "pnpm -F @solar/e2e test",
    "db:generate": "pnpm -F @solar/db prisma:generate",
    "db:validate": "pnpm -F @solar/db prisma:validate",
    "db:migrate:dev": "pnpm -F @solar/db prisma:migrate:dev",
    "db:migrate:deploy": "pnpm -F @solar/db prisma:migrate:deploy",
    "db:studio": "pnpm -F @solar/db prisma:studio",
    "db:seed": "pnpm -F @solar/db db:seed",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "prisma"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
