# Solar-SaaS — environment variable template.
#
# Copy to `.env.local` for local dev (gitignored). Production values live in
# Railway env vars dashboard. **Never commit a populated `.env` file.**
#
# Production checklist (Railway):
#   1. Set DATABASE_URL + DIRECT_URL to Railway-injected Postgres values.
#   2. Set AUTH_SECRET, PII_ENCRYPTION_KEY to freshly-generated secrets.
#   3. Set AUTH_URL / NEXT_PUBLIC_APP_URL to the custom domain.
#   4. Set AUTH_TRUST_HOST="true" (Railway runs behind a proxy).
#   5. Set NODE_ENV="production".
#   6. Fill in all RESEND_*, R2_*, SENTRY_* values.

# ---------------------------------------------------------------------------
# Database (PostgreSQL — see docker-compose.dev.yml, port 5434)
# ---------------------------------------------------------------------------
# DATABASE_URL   : connection used by the app (PgBouncer-safe / pooled).
# DIRECT_URL     : direct (non-pooled) connection used by `prisma migrate deploy`.
#                  Railway injects both automatically when the Postgres plugin is
#                  linked; set DIRECT_URL = DATABASE_URL for local dev.
DATABASE_URL="postgresql://solar:solar_dev_pw@localhost:5434/solar_saas_dev?schema=public"
DIRECT_URL="postgresql://solar:solar_dev_pw@localhost:5434/solar_saas_dev?schema=public"

# ---------------------------------------------------------------------------
# Auth.js v5 (T-01-05)
# ---------------------------------------------------------------------------
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-32-byte-base64"
# AUTH_URL / NEXT_PUBLIC_APP_URL: full origin of the web service.
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Required when running behind a reverse proxy (Railway, Cloudflare, etc.).
AUTH_TRUST_HOST="false"
AUTH_SESSION_MAX_AGE_SEC="86400"

# TOTP issuer label displayed in authenticator apps.
TOTP_ISSUER="Solar SaaS"

# TOTP secret 等の PII 暗号化共通キー (docs/05 §12).
# 64 hex chars = 32 bytes = 256-bit key for AES-256-GCM. Generate with:
#   openssl rand -hex 32
PII_ENCRYPTION_KEY="replace-me-with-64-hex-chars"

# ---------------------------------------------------------------------------
# Email — Resend (T-01-07, T-01-10)
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_dev_placeholder"
RESEND_FROM_ADDRESS="no-reply@solar-saas.local"
# Alias of RESEND_FROM_ADDRESS — either variable is honoured by @solar/email.
RESEND_FROM="no-reply@solar-saas.local"
# Set to "true" in dev to short-circuit deliveries to the test inbox.
RESEND_TEST_MODE="true"

# ---------------------------------------------------------------------------
# Object storage — Cloudflare R2 (T-01-10)
# ---------------------------------------------------------------------------
# Either set R2_ENDPOINT directly or supply R2_ACCOUNT_ID and the endpoint
# will be derived (https://<account>.r2.cloudflarestorage.com).
R2_ENDPOINT=""
R2_ACCOUNT_ID="replace-me"
R2_ACCESS_KEY_ID="replace-me"
R2_SECRET_ACCESS_KEY="replace-me"
R2_BUCKET="solar-saas-dev"
R2_PUBLIC_BASE_URL="https://pub-replace-me.r2.dev"

# ---------------------------------------------------------------------------
# Observability — Sentry / logging (T-01-11)
# ---------------------------------------------------------------------------
# Server-side (Node / Edge / worker). Leave blank in local dev to disable Sentry.
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
# Browser-side (must be NEXT_PUBLIC_* to be inlined at build time).
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
# Source-maps upload — set all three to enable upload during `next build`.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# pino log level (trace | debug | info | warn | error | fatal). Production
# should set "info"; dev defaults to debug.
LOG_LEVEL="debug"
# Set to "false" to force JSON output even in dev (e.g. when piping to jq).
LOG_PRETTY="true"

# ---------------------------------------------------------------------------
# graphile-worker (T-01-10)
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY="4"
WORKER_POLL_INTERVAL_MS="2000"

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# LINE notifications and CSV import are Phase 2 features; keep false in MVP.
FEATURE_LINE_NOTIFICATIONS="false"
FEATURE_CSV_IMPORT="false"

# Phase 2: LINE Messaging API (leave blank until Phase 2)
# LINE_CHANNEL_SECRET=""
# LINE_CHANNEL_ACCESS_TOKEN=""

# ---------------------------------------------------------------------------
# App-level
# ---------------------------------------------------------------------------
# Set "production" in Railway env vars. Do NOT set this in .env.local.
NODE_ENV="development"
